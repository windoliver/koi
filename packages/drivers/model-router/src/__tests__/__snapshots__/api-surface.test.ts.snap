 * @param onChunk - Called on each raw chunk for idle timeout reset
 */
declare function parseSSEStream<T>(body: ReadableStream<Uint8Array>, parseLine: (data: string) => T | undefined, onChunk?: () => void): AsyncGenerator<T>;

/**
 * OpenAI provider adapter.
 *
 * Normalizes OpenAI chat completion API to the ProviderAdapter interface.
 * Uses raw fetch — no SDK dependency.
 */

/**
 * Creates an OpenAI provider adapter.
