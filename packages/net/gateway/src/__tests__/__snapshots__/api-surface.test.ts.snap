type SchedulerDispatcher = (session: Session, frame: GatewayFrame) => void;
interface GatewayScheduler {
    readonly start: () => void;
    readonly stop: () => void;
    readonly count: () => number;
}
declare function createScheduler(defs: readonly SchedulerDef[], dispatcher: SchedulerDispatcher): GatewayScheduler;

/**
 * SequenceTracker: ordering + deduplication via a sliding window.
 *
