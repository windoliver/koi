{
  "name": "@koi/channel-slack",
  "description": "Connect Slack bots via Socket Mode or HTTP Events API",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@koi/channel-base": "workspace:*",
    "@koi/core": "workspace:*",
    "@koi/resolve": "workspace:*",
