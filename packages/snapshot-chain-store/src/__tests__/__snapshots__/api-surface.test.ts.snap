// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`@koi/snapshot-chain-store API surface . has stable type surface 1`] = `
"import { SnapshotChainStore, ThreadSnapshotStore, ThreadStore } from '@koi/core';

/**
 * InMemorySnapshotChainStore — Map-based store for tests and development.
 *
 * No persistence across restarts. Supports full DAG topology,
 * content-hash deduplication, ancestor walking, forking, and pruning.
 */

declare function createInMemorySnapshotChainStore<T>(): SnapshotChainStore<T>;

/**
 * ThreadStore facade — thin adapter over SnapshotChainStore<ThreadSnapshot>.
 *
 * Maps ThreadId → ChainId (identity), provides idempotent append-and-checkpoint,
 * and deduplicates messages by ThreadMessageId (Decision 6A).
 */

interface CreateThreadStoreConfig {
    readonly store: ThreadSnapshotStore;
}
/**
 * Create a ThreadStore backed by a SnapshotChainStore<ThreadSnapshot>.
 *
 * Idempotency: duplicate ThreadMessageId values produce a CONFLICT error
 * (Decision 6A). The idempotency set is maintained in-memory per thread.
 */
declare function createThreadStore(config: CreateThreadStoreConfig): ThreadStore;

export { type CreateThreadStoreConfig, createInMemorySnapshotChainStore, createThreadStore };
"
`;
