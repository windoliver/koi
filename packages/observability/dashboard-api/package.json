{
  "name": "@koi/dashboard-api",
  "description": "Serve REST endpoints + SSE events for agent/channel/skill dashboard metrics",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@koi/core": "workspace:*",
    "@koi/dashboard-types": "workspace:*"
  },
  "devDependencies": {
    "@koi/engine": "workspace:*",
    "@koi/engine-pi": "workspace:*",
    "@koi/node": "workspace:*",
    "@koi/test-utils": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test",
    "test:api": "bun test src/__tests__/api-surface.test.ts"
  }
}
