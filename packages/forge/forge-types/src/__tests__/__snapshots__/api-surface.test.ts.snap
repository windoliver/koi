    readonly code: "AUDIT_FAILED" | "ENGINE_RESOLVE_FAILED" | "INSTALL_FAILED" | "INSTALL_TIMEOUT" | "INTEGRITY_MISMATCH" | "WORKSPACE_FAILED";
