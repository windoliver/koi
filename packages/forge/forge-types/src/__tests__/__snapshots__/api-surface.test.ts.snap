    /** Spawns an external coding agent to produce implementation code. Injected by L3 consumer. */
    readonly spawnCodingAgent?: (agent: ExternalAgentDescriptor, prompt: string, options: DelegateOptions) => Promise<Result<string, KoiError>>;
