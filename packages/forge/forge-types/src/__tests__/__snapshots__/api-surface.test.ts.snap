declare function isVisibleToAgent(brick: BrickArtifact, agentId: string, zoneId?: string | undefined): boolean;
/**
 * Filters an array of bricks to only those visible to the specified agent.
 */
declare function filterByAgentScope(bricks: readonly BrickArtifact[], agentId: string, zoneId?: string | undefined): readonly BrickArtifact[];

export { type ArtifactBuilder, type BrickContentInput, type CreateProvenanceOptions, DEFAULT_ATTESTATION_CACHE_CAP, DEFAULT_REVERIFICATION_CONFIG, DEFAULT_SANDBOX_TIMEOUT_MS, type DelegateOptions, type DependencyConfig, type DriftCheckResult, type DriftChecker, type ForgeAgentInput, type ForgeAgentInputWithBricks, type ForgeAgentInputWithManifest, type ForgeChannelInput, type ForgeCompositeInput, type ForgeConfig, type ForgeContext, type ForgeDeps, type ForgeError, type ForgeInput, type ForgeInputBase, type ForgeMiddlewareInput, type ForgePipeline, type ForgeResult, type ForgeResultMetadata, type ForgeRunner, type ForgeSkillInput, type ForgeToolInput, type ForgeVerifier, type FormatConfig, type GovernanceResult, MAX_EXTERNAL_LISTENERS, type ManifestParseResult, type ManifestParser, type MutationPressureConfig, type PromoteChange, type PromoteResult, type ResolveStageReport, type ReverificationConfig, type ScopePromotionConfig, type SelfTestStageReport, type StageReport, type TestFailure, type TrustStageReport, type VerificationConfig, type VerificationReport, type VerificationStage, type VerifierResult, computeTtl, createDefaultForgeConfig, delegationError, filterByAgentScope, formatError, governanceError, isStale, isVisibleToAgent, resolveError, sandboxError, selfTestError, staticError, storeError, trustError, typeError, validateForgeConfig };
