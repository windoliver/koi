declare function resolveConfig<T extends Record<string, unknown>>(schema: z.ZodType<T>, defaults: T, raw: unknown, prefix?: string): Result<T, KoiError>;

/**
 * Bridge from KoiConfig to engine-compatible runtime options.
 */

/** Engine-compatible runtime options derived from KoiConfig. */
interface ResolvedKoiOptions {
    readonly logLevel: LogLevel;
    readonly limits: LimitsConfig;
