declare function validateKoiConfig(raw: unknown): Result<KoiConfig, KoiError>;
/**
 * Returns a JSON Schema representation of the KoiConfig schema.
 *
 * Useful for IDE autocompletion in YAML/JSON config files.
 */
declare function getKoiConfigJsonSchema(): Record<string, unknown>;

/**
 * Slice subscription with ref-equality skip for config stores.
 */

/**
 * Subscribes to a config store but only fires \`listener\` when the selected
 * slice changes by reference (===).
 *
 * Returns an unsubscribe function.
 */
declare function selectConfig<T, S>(store: ConfigStore<T>, selector: (config: T) => S, listener: (next: S, prev: S) => void): ConfigUnsubscribe;

/**
 * Debounced file watcher for config hot-reload.
 */

/** Options for \`watchConfigFile()\`. */
interface WatchConfigOptions {
    /** Absolute path to the config file. */
    readonly filePath: string;
    /** Callback invoked (debounced) when the file changes. */
    readonly onChange: () => void | Promise<void>;
    /** Debounce interval in milliseconds. Defaults to 300. */
    readonly debounceMs?: number | undefined;
}
/**
 * Watches a config file for changes using \`fs.watch()\`.
 *
 * Returns an unsubscribe function that stops watching.
 * Multiple rapid writes are coalesced by the debounce interval.
 */
declare function watchConfigFile(options: WatchConfigOptions): ConfigUnsubscribe;

