 *
 * Starts with \`DEFAULT_KOI_CONFIG\` — call \`reload()\` to load from disk.
 */
declare function createConfigManager(options: CreateConfigManagerOptions): ConfigManager;

/**
 * Generic config resolution: validate raw input, merge with defaults.
 */

/**
