// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`@koi/git-utils API surface . has stable type surface 1`] = `
"import { Result, KoiError } from '@koi/core';

/**
 * Git diff utilities — changed file detection for drift scoring.
 *
 * Wraps \`runGit\` to extract lists of changed files and HEAD commit hashes.
 */

/**
 * List files changed since a given commit.
 *
 * Uses \`git diff --name-only <commit>\` to detect changed files.
 * Side-effect: spawns a child process.
 *
 * @param commit - Base commit hash to diff against.
 * @param cwd - Working directory for the git command.
 * @returns List of changed file paths relative to the repo root.
 */
declare function changedFilesSince(commit: string, cwd: string): Promise<Result<readonly string[], KoiError>>;
/**
 * Get the current HEAD commit hash.
 *
 * Uses \`git rev-parse HEAD\` to retrieve the full SHA.
 * Side-effect: spawns a child process.
 *
 * @param cwd - Working directory for the git command.
 * @returns The full 40-character commit hash.
 */
declare function getHeadCommit(cwd: string): Promise<Result<string, KoiError>>;

/**
 * Path resolution utilities for git worktrees.
 */
/** Resolve the base path for worktrees relative to the repo. */
declare function resolveWorktreeBasePath(repoPath: string, explicit?: string): string;

/**
 * Git command execution utilities.
 *
 * Thin wrapper around Bun.spawn for running git commands and
 * mapping stderr to KoiError values.
 */

/**
 * Run a git command and return the stdout as a Result.
 *
 * On non-zero exit, returns a Result.error with the stderr parsed
 * into a KoiError. Side-effect: spawns a child process.
 */
declare function runGit(args: readonly string[], cwd: string): Promise<Result<string, KoiError>>;
/** Map git stderr messages to structured KoiError values. */
declare function parseGitError(stderr: string, args: readonly string[]): KoiError;

export { changedFilesSince, getHeadCommit, parseGitError, resolveWorktreeBasePath, runGit };
"
`;
