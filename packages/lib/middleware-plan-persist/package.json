{
  "name": "@koi/middleware-plan-persist",
  "description": "File-backed persistence for write_plan — saves plans to .koi/plans/<ts>-<slug>.md and loads them back",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test"
  },
  "koi": {
    "optional": true
  },
  "dependencies": {
    "@koi/core": "workspace:*",
    "@koi/errors": "workspace:*"
  }
}
