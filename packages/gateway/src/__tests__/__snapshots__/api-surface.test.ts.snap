    readonly close: () => void;
    readonly connections: () => number;
}
interface BunTransport extends Transport {
    /** The actual port the server is listening on (useful when binding to port 0). */
    readonly port: () => number;
}
declare function createBunTransport(): BunTransport;

/**
 * Authentication: handshake + periodic heartbeat re-validation.
 */

interface GatewayAuthenticator {
    /** Authenticate based on a structured connect frame. */
