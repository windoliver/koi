 */
declare function resolveRoute(config: RoutingConfig | undefined, routing: RoutingContext | undefined, fallbackAgentId: string): ResolvedRoute;

/**
 * Scheduler: timer-based periodic frame generation.
 * Each SchedulerDef produces GatewayFrames at a fixed interval.
