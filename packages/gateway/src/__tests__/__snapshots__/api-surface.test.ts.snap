}
declare function createWebhookServer(config: WebhookConfig, dispatcher: WebhookDispatcher, authenticator?: WebhookAuthenticator): WebhookServer;

/**
 * Gateway factory: wires transport, auth, sessions, sequencing,
 * and backpressure into a single control-plane entry point.
 */

interface Gateway {
    readonly start: (port: number) => Promise<void>;
    readonly stop: () => Promise<void>;
    readonly sessions: () => SessionStore;
