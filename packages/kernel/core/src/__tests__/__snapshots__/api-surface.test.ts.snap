     * failure (spawn crash, verdict parse error, etc.). Used by the
     * registry to distinguish abort artifacts from genuine failures
     * when refunding claimed once-hooks under cancellation.
     */
    readonly aborted?: boolean | undefined;
} | {
    readonly ok: false;
    readonly hookName: string;
    readonly error: string;
    readonly durationMs: number;
    /** Whether this hook's failure should suppress output. Default: true. */
    readonly failClosed?: boolean | undefined;
    /**
     * When true, this failure was caused by caller cancellation (abort
     * signal), not a deterministic execution error. Used by the registry
     * to refund claimed once-hooks without burning retry budget on
     * cancellation races. Set by executor.ts on abort-shaped exceptions.
     */
    readonly aborted?: boolean | undefined;
};
