{
  "name": "@koi/nexus",
  "description": "One-line Nexus wiring: single config, all backends auto-wired, auto-provisioned, auto-scoped per agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@koi/core": "workspace:*",
    "@koi/nexus-client": "workspace:*",
    "@koi/registry-nexus": "workspace:*",
    "@koi/permissions-nexus": "workspace:*",
    "@koi/audit-sink-nexus": "workspace:*",
    "@koi/search-nexus": "workspace:*",
    "@koi/scheduler-nexus": "workspace:*",
    "@koi/pay-nexus": "workspace:*",
    "@koi/name-service-nexus": "workspace:*",
    "@koi/gateway-nexus": "workspace:*",
    "@koi/nexus-store": "workspace:*",
    "@koi/filesystem-nexus": "workspace:*",
    "@koi/ipc-nexus": "workspace:*",
    "@koi/scratchpad-nexus": "workspace:*",
    "@koi/workspace-nexus": "workspace:*"
  },
  "devDependencies": {
    "@koi/test-utils": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test",
    "test:api": "bun test src/__tests__/api-surface.test.ts"
  }
}
