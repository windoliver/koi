// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`@koi/skill-stack API surface . has stable type surface 1`] = `
"import { Severity } from '@koi/validation';
import { KoiMiddleware, SkillConfig, Result, KoiError, ForgeStore, ComponentProvider, StoreChangeNotifier, CredentialComponent, BrickRequires } from '@koi/core';
import { ScanFinding } from '@koi/skill-scanner';
import { ProgressiveSkillProvider } from '@koi/skills';

/**
 * Configuration and bundle types for @koi/skill-stack.
 */

type SkillStackPreset = "restrictive" | "standard" | "permissive";
interface SkillUserConfig {
    readonly [skillName: string]: {
        readonly enabled?: boolean;
        readonly env?: Readonly<Record<string, string>>;
    };
}
interface SkillStackConfig {
    readonly skills: readonly SkillConfig[];
    readonly basePath: string;
    readonly store?: ForgeStore;
    readonly preset?: SkillStackPreset;
    readonly overrideDirs?: readonly string[];
    readonly userConfig?: SkillUserConfig;
    readonly watch?: boolean;
    readonly watchDebounceMs?: number;
    readonly onSecurityFinding?: (name: string, findings: readonly ScanFinding[]) => void;
    /** Optional forge tools ComponentProvider — bridge via watch() for ComponentEvent. */
    readonly forgeProvider?: ComponentProvider;
    /** Optional store change notifier — bridge via subscribe() for StoreChangeEvent. */
    readonly notifier?: StoreChangeNotifier;
    /** Optional credential component for async credential-aware gating. */
    readonly credentialComponent?: CredentialComponent;
    /** Optional requires map (skill name -> BrickRequires). When provided, enables credential gating. */
    readonly requiresMap?: ReadonlyMap<string, BrickRequires>;
}
interface SkillStackBundle {
    readonly provider: ProgressiveSkillProvider;
    readonly middleware: readonly KoiMiddleware[];
    readonly mount: (skill: SkillConfig) => Promise<Result<void, KoiError>>;
    readonly unmount: (name: string) => void;
    readonly dispose: () => void;
    readonly config: ResolvedSkillStackMeta;
}
interface ResolvedSkillStackMeta {
    readonly preset: SkillStackPreset;
    readonly skillCount: number;
    readonly watcherCount: number;
    readonly gatingEnabled: boolean;
}

/**
 * Skill-stack deployment presets.
 *
 * Each preset defines a security severity threshold and watch default.
 */

interface SkillStackPresetSpec {
    /** Reject skills with findings at or above this severity. */
    readonly securityThreshold: Severity;
    /** Whether file watching is enabled by default. */
    readonly watchDefault: boolean;
}
declare const SKILL_STACK_PRESET_SPECS: Readonly<Record<SkillStackPreset, SkillStackPresetSpec>>;

/**
 * createSkillStack — factory that composes skill providers, gating,
 * middleware, and optional file watchers into a single bundle.
 */

/**
 * Creates a skill-stack bundle that composes:
 * - Gating (filter skills by requirements)
 * - Progressive provider (metadata → body → bundled)
 * - Skill activator middleware (auto-promote on reference)
 * - Optional file watcher (hot-plug on fs changes)
 * - Optional forge→mount bridge (via ComponentEvent)
 */
declare function createSkillStack(config: SkillStackConfig): Promise<SkillStackBundle>;

export { type ResolvedSkillStackMeta, SKILL_STACK_PRESET_SPECS, type SkillStackBundle, type SkillStackConfig, type SkillStackPreset, type SkillStackPresetSpec, type SkillUserConfig, createSkillStack };
"
`;
