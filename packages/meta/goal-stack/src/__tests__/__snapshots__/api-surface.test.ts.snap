// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`@koi/goal-stack API surface . has stable type surface 1`] = `
"import { GoalAnchorConfig } from '@koi/middleware-goal-anchor';
export { GoalAnchorConfig, TodoItem, TodoItemStatus, TodoState } from '@koi/middleware-goal-anchor';
import { GoalReminderConfig } from '@koi/middleware-goal-reminder';
export { GoalReminderConfig, ReminderSessionState, ReminderSource } from '@koi/middleware-goal-reminder';
import { PlanConfig } from '@koi/middleware-planning';
export { PlanConfig, PlanItem, PlanStatus } from '@koi/middleware-planning';
import { KoiMiddleware } from '@koi/core';

/**
 * Types for the goal-stack L3 bundle.
 *
 * Reuses L2 config types directly (GoalAnchorConfig, GoalReminderConfig, PlanConfig)
 * to avoid type drift. Presets only control which middleware to enable — they don't
 * supply domain values like objectives or sources.
 */

/** Resolved config returned by \`resolveGoalStackConfig()\`. */
interface ResolvedGoalStackConfig {
    readonly planning: Omit<PlanConfig, "priority"> | undefined;
    readonly anchor: GoalAnchorConfig | undefined;
    readonly reminder: GoalReminderConfig | undefined;
    readonly meta: ResolvedGoalStackMeta;
}
/** Which middleware are enabled by default. */
type GoalStackPreset = "light" | "standard" | "full";
/**
 * Top-level config for the goal stack bundle.
 *
 * - \`preset\` selects which middleware are enabled by default (default: "light")
 * - Providing a middleware config explicitly enables it regardless of preset
 * - Priority is blocked on planning to preserve stack ordering (330, 340, 450)
 */
interface GoalStackConfig {
    readonly preset?: GoalStackPreset | undefined;
    readonly anchor?: GoalAnchorConfig | undefined;
    readonly reminder?: GoalReminderConfig | undefined;
    readonly planning?: Omit<PlanConfig, "priority"> | undefined;
}
/** Per-preset flags controlling which middleware are enabled. */
interface GoalStackPresetFlags {
    readonly planning: boolean;
    readonly anchor: boolean;
    readonly reminder: boolean;
}
/** Inspection metadata returned alongside the assembled middleware array. */
interface ResolvedGoalStackMeta {
    readonly preset: GoalStackPreset;
    readonly middlewareCount: number;
    readonly planning: boolean;
    readonly anchor: boolean;
    readonly reminder: boolean;
}
/** Return value of \`createGoalStack()\`. */
interface GoalStackBundle {
    readonly middlewares: readonly KoiMiddleware[];
    readonly config: ResolvedGoalStackMeta;
}

/**
 * Config resolution for the goal stack bundle.
 *
 * Determines which middleware are enabled based on preset flags and explicit config.
 * Validates that enabled middleware have required config values.
 */

/**
 * Resolve goal stack config by merging preset flags with explicit config.
 *
 * Rules:
 * - Middleware is enabled if its preset flag is true OR user provides its config
 * - If enabled by preset but no config provided, throws with a clear message
 *   (exception: planning, whose config is fully optional)
 */
declare function resolveGoalStackConfig(config?: GoalStackConfig): ResolvedGoalStackConfig;

/**
 * Factory for the goal stack bundle.
 *
 * Composes up to 3 goal-management middleware into a single bundle:
 *   - goal-reminder (priority 330)
 *   - goal-anchor   (priority 340)
 *   - plan           (priority 450)
 */

/**
 * Create a goal management stack from config.
 *
 * Returns an ordered array of middleware (ascending priority: 330, 340, 450)
 * plus metadata for inspection.
 */
declare function createGoalStack(config?: GoalStackConfig): GoalStackBundle;

/**
 * Frozen preset flags for the goal stack.
 *
 * Presets only control which middleware are enabled — they cannot supply
 * domain-specific config values like objectives or sources. Providing
 * explicit middleware config always wins (e.g., anchor config with "light"
 * preset still enables anchor).
 */

/** Frozen preset flag registry. */
declare const GOAL_STACK_PRESET_FLAGS: Readonly<Record<GoalStackPreset, GoalStackPresetFlags>>;

export { GOAL_STACK_PRESET_FLAGS, type GoalStackBundle, type GoalStackConfig, type GoalStackPreset, type GoalStackPresetFlags, type ResolvedGoalStackConfig, type ResolvedGoalStackMeta, createGoalStack, resolveGoalStackConfig };
"
`;
