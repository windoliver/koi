      },
      {
        "name": "EnterPlanMode",
        "description": "Switch to plan mode for complex tasks that require exploration and design before any file changes. In plan mode you MUST NOT write or edit files — only read, search, and explore. When ready, call ExitPlanMode to present your plan for approval."
      },
      {
        "name": "ExitPlanMode",
        "description": "Present your completed plan and request approval to exit plan mode and begin implementation. Call this only after you have written a thorough plan. Pass your plan as plan_content — it is required and must be non-empty."
      }
    ]
  },
