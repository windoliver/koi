declare function applyDataModelUpdate(surface: CanvasSurface, updates: readonly A2uiDataModelUpdate[]): Result<CanvasSurface, KoiError>;
/** Gets a component from a surface by ID. */
declare function getComponent(surface: CanvasSurface, id: ComponentId): CanvasElement | undefined;

/**
 * Top-level validators composing Zod schema + semantic checks.
