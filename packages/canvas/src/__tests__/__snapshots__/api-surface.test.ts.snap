/** Maps an A2UI protocol component to a Koi CanvasElement. */
declare function mapA2uiComponent(component: A2uiComponent): CanvasElement;
/** Maps a Koi CanvasElement back to an A2UI protocol component. */
declare function mapCanvasElement(element: CanvasElement): A2uiComponent;
