// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`@koi/skill-scanner API surface . has stable type surface 1`] = `
"import { Program } from 'oxc-parser';

/**
 * Scanner-specific types for @koi/skill-scanner.
 *
 * All types live in L2 — no L0 changes required.
 */

/**
 * Severity levels — mirrored from @koi/validation.
 * Kept local to avoid tsup DTS cross-package re-export resolution issues.
 */
type Severity = "CRITICAL" | "HIGH" | "MEDIUM" | "LOW";
type ScanCategory = "DANGEROUS_API" | "OBFUSCATION" | "EXFILTRATION" | "PROTOTYPE_POLLUTION" | "FILESYSTEM_ABUSE" | "SSRF" | "PROMPT_INJECTION" | "SECRETS" | "UNPARSEABLE";
interface ScanLocation {
    readonly line: number;
    readonly column: number;
    readonly endLine?: number;
    readonly endColumn?: number;
}
interface ScanFinding {
    readonly rule: string;
    readonly severity: Severity;
    readonly confidence: number;
    readonly category: ScanCategory;
    readonly message: string;
    readonly location?: ScanLocation;
}
interface ScanReport {
    readonly findings: readonly ScanFinding[];
    readonly durationMs: number;
    readonly parseErrors: number;
    readonly rulesApplied: number;
}
interface ScanContext {
    readonly program: Program;
    readonly sourceText: string;
    readonly filename: string;
    readonly config?: ScannerConfig;
}
interface ScanRule {
    readonly name: string;
    readonly category: ScanCategory;
    readonly defaultSeverity: Severity;
    readonly check: (ctx: ScanContext) => readonly ScanFinding[];
}
interface ScannerConfig {
    readonly enabledCategories?: readonly ScanCategory[];
    readonly severityThreshold?: Severity;
    readonly confidenceThreshold?: number;
    readonly trustedDomains?: readonly string[];
}

/**
 * ForgeVerifier adapter — thin wrapper around the scanner for forge Stage 3.
 *
 * Defines its own compatible interfaces (L2 can't import L2 peers).
 * TypeScript structural typing ensures compatibility with @koi/forge types.
 */

interface ForgeVerifierCompat {
    readonly name: string;
    readonly verify: (input: ForgeInputCompat, context: ForgeContextCompat) => Promise<VerifierResultCompat>;
}
interface VerifierResultCompat {
    readonly passed: boolean;
    readonly message?: string;
}
interface ForgeInputCompat {
    readonly kind: string;
    readonly name: string;
    readonly description: string;
    readonly implementation?: string;
    readonly content?: string;
}
interface ForgeContextCompat {
    readonly agentId: string;
    readonly depth: number;
    readonly sessionId: string;
}
declare function createScannerVerifier(config?: ScannerConfig): ForgeVerifierCompat;

/**
 * Rule registry — all built-in scan rules.
 */

declare function getBuiltinRules(): readonly ScanRule[];
declare function getTextRules(): readonly ScanRule[];
declare function getRulesByCategory(category: ScanCategory): readonly ScanRule[];

/**
 * Scanner factory — the main public API of @koi/skill-scanner.
 *
 * Creates a scanner instance that parses code, runs all enabled rules,
 * and returns a filtered ScanReport.
 */

interface Scanner {
    readonly scan: (sourceText: string, filename?: string) => ScanReport;
    readonly scanSkill: (markdown: string) => ScanReport;
}
declare function createScanner(config?: ScannerConfig): Scanner;

export { type ForgeContextCompat, type ForgeInputCompat, type ForgeVerifierCompat, type ScanCategory, type ScanContext, type ScanFinding, type ScanLocation, type ScanReport, type ScanRule, type Scanner, type ScannerConfig, type Severity, type VerifierResultCompat, createScanner, createScannerVerifier, getBuiltinRules, getRulesByCategory, getTextRules };
"
`;
