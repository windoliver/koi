{
  "name": "@koi/nexus-store",
  "description": "Consolidate Nexus-backed persistence adapters for forge, events, snapshots, sessions, and memory",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ace": {
      "types": "./dist/ace.d.ts",
      "import": "./dist/ace.js"
    },
    "./forge": {
      "types": "./dist/forge.d.ts",
      "import": "./dist/forge.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js"
    },
    "./snapshots": {
      "types": "./dist/snapshots.d.ts",
      "import": "./dist/snapshots.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "import": "./dist/memory.js"
    }
  },
  "dependencies": {
    "@koi/ace-types": "workspace:*",
    "@koi/core": "workspace:*",
    "@koi/event-delivery": "workspace:*",
    "@koi/hash": "workspace:*",
    "@koi/nexus-client": "workspace:*",
    "@koi/validation": "workspace:*"
  },
  "devDependencies": {
    "@koi/test-utils": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test"
  }
}
