 * Lazy factories are resolved on first retry, enabling post-construction wiring
 * (e.g., creating the strategy after the FeedbackLoopHandle is available).
 */
type RepairStrategyInput = RepairStrategy | (() => RepairStrategy);

/** Enriched error feedback returned to the agent when a tool is quarantined or degraded. */
interface ForgeToolErrorFeedback {
    readonly error: string;
    readonly errorRate: number;
    readonly recentFailures: readonly ToolFailureRecord[];
    readonly suggestion: string;
}
/** Reason for a trust tier demotion. */
type TrustDemotionReason = "error_rate" | "dependency_failure" | "manual" | "re_verification_failed" | "source_drift";
/** Event emitted when a tool's trust tier is demoted. */
interface TrustDemotionEvent {
    readonly brickId: string;
