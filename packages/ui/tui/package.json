{
  "name": "@koi/tui",
  "description": "OpenTUI-based terminal UI for Koi agent conversations",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/permission-bridge.d.ts",
      "import": "./dist/bridge/permission-bridge.js"
    },
    "./commands": {
      "types": "./dist/commands/slash-detection.d.ts",
      "import": "./dist/commands/slash-detection.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    }
  },
  "dependencies": {
    "@koi/core": "workspace:*",
    "@opentui/core": "0.1.87",
    "@opentui/react": "0.1.87",
    "react": "19.1.0"
  },
  "devDependencies": {
    "@types/react": "19"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test"
  },
  "koi": {
    "optional": true
  }
}
