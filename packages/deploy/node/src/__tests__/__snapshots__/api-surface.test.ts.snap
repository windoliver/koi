/** Discriminated union of all frame kinds flowing over the Node <-> Gateway WS. */
type NodeFrameKind = "agent:dispatch" | "agent:message" | "agent:signal" | "agent:signal_group" | "agent:status" | "agent:terminate" | "node:auth" | "node:auth_challenge" | "node:auth_response" | "node:auth_ack" | "node:handshake" | "node:heartbeat" | "node:capacity" | "node:capabilities" | "node:error" | "tool_call" | "tool_result" | "tool_error";
