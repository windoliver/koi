declare function signChallenge(challenge: string, secret: string): Promise<string>;
/** Create the initial auth payload with token and current timestamp. */
declare function createAuthPayload(token: string): AuthPayload;
declare function createAuthHandshake(nodeId: string, config: AuthHandshakeConfig): AuthHandshake;

/**
