{
  "name": "@koi/sandbox-ipc",
  "description": "Bridge OS-level sandboxing with forge verification via structured IPC",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@koi/core": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@koi/sandbox": "workspace:*"
  },
  "scripts": {
    "prebuild": "bun run scripts/generate-worker-source.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test",
    "test:api": "bun test src/__tests__/api-surface.test.ts"
  }
}
