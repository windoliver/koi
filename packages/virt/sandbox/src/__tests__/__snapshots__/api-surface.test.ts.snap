"import { SandboxAdapter, TrustTier, SandboxProfile, Result, KoiError, SandboxAdapterResult } from '@koi/core';
export { FilesystemPolicy, NetworkPolicy, ResourceLimits, SandboxAdapter, SandboxAdapterResult, SandboxExecOptions, SandboxInstance, SandboxProfile, SandboxAdapterResult as SandboxResult } from '@koi/core';

/**
 * OS-level SandboxAdapter implementation.
 *
 * Wraps the stateless execute()/spawn() APIs into the stateful
 * SandboxAdapter/SandboxInstance contract from @koi/core.
 *
 * For OS-level sandboxing there is no persistent VM — each exec() call
 * creates a new sandboxed process. readFile/writeFile operate on the
 * host filesystem (the OS sandbox restricts what the process can access).
 */

/**
 * Create an OS-level SandboxAdapter.
 *
 * The returned adapter uses macOS Seatbelt or Linux bubblewrap
 * depending on the current platform.
 */
declare function createOsAdapter(): SandboxAdapter;

/**
 * Sandbox types — re-exports from @koi/core (L0) + local aliases.
 *
 * Adapter types (SandboxAdapter, SandboxInstance, SandboxExecOptions, SandboxAdapterResult)
 * are canonical in @koi/core. This module re-exports them for backward compatibility
 * and adds the SandboxTier alias.
 */

/** Sandbox-specific alias for the L0 TrustTier. */
type SandboxTier = TrustTier;

/**
 * createSandboxCommand() — shared sandbox command construction.
 *
 * Extracts the duplicated platform-detection + args-building logic
 * from execute.ts and spawn.ts into a single reusable function.
 */

interface SandboxCommand {
    readonly executable: string;
    readonly args: readonly string[];
}
/**
 * Create the platform-appropriate sandbox command for a given profile.
 *
 * Detects the current platform (macOS → seatbelt, Linux → bwrap),
 * constructs the full argument list, and validates the result.
 */
declare function createSandboxCommand(profile: SandboxProfile, command: string, args: readonly string[]): Result<SandboxCommand, KoiError>;

/**
 * Platform detection and sandbox availability checking.
 */

type SandboxPlatform = "seatbelt" | "bwrap";
interface PlatformInfo {
    readonly platform: SandboxPlatform;
    readonly available: boolean;
    readonly reason?: string;
}
declare function checkAvailability(): Result<PlatformInfo, KoiError>;

/**
 * execute() — Buffered sandbox execution API.
 * Runs a command in a sandboxed process and collects output.
 */

interface ExecuteOptions {
    readonly cwd?: string;
    readonly env?: Readonly<Record<string, string>>;
    readonly stdin?: string;
}
declare function execute(profile: SandboxProfile, command: string, args: readonly string[], options?: ExecuteOptions): Promise<Result<SandboxAdapterResult, KoiError>>;

/**
 * Preset sandbox profile constructors.
 */

declare function restrictiveProfile(overrides?: Partial<SandboxProfile>): SandboxProfile;
declare function permissiveProfile(overrides?: Partial<SandboxProfile>): SandboxProfile;
declare function profileForTier(tier: TrustTier): SandboxProfile;

/**
 * spawn() — Streaming sandbox process API.
 * Spawns a sandboxed process with direct stream access.
 */

interface SpawnOptions {
    readonly cwd?: string;
    readonly env?: Readonly<Record<string, string>>;
}
interface SandboxProcess {
    readonly pid: number;
    readonly stdout: ReadableStream<Uint8Array>;
    readonly stderr: ReadableStream<Uint8Array>;
    readonly stdin: {
        write(data: string | Uint8Array): number | Promise<number>;
        end(): void;
    };
    readonly exited: Promise<number>;
    readonly kill: (signal?: number) => void;
}
declare function spawn(profile: SandboxProfile, command: string, args: readonly string[], options?: SpawnOptions): Result<SandboxProcess, KoiError>;

export { type ExecuteOptions, type PlatformInfo, type SandboxCommand, type SandboxProcess, type SandboxTier, type SpawnOptions, checkAvailability, createOsAdapter, createSandboxCommand, execute, permissiveProfile, profileForTier, restrictiveProfile, spawn };
"
