    readonly getBySession: (sessionId: SessionId) => readonly RunReport[] | Promise<readonly RunReport[]>;
}

export type { ActionEntry, IssueEntry, ReportStore, ReportSummary, RunCost, RunDuration, RunReport };
"
`;

