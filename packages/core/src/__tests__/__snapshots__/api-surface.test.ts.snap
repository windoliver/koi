    readonly kind: "proposal:reviewed";
    readonly proposalId: ProposalId;
    readonly decision: ReviewDecision;
} | {
    readonly kind: "proposal:expired";
    readonly proposalId: ProposalId;
} | {
    readonly kind: "proposal:superseded";
    readonly proposalId: ProposalId;
