 * If the underlying LLM summarizer breaks, throw with \`cause\`.
 */
interface ContextCompactor {
    readonly compact: (messages: readonly InboundMessage[], maxTokens: number, model?: string) => CompactionResult | Promise<CompactionResult>;
}

