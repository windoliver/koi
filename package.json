{
  "name": "koi",
  "description": "Koi monorepo: self-extending agent engine with layered architecture, middleware, and governance",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "workspaces": [
    "packages/*/*",
    "apps/*",
    "tests/e2e",
    "recipes/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:cli": "bunx turbo run build --filter=@koi/cli",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:layers": "bun scripts/check-layers.ts",
    "check:descriptions": "bun scripts/check-descriptions.ts",
    "check:doc-sync": "bun scripts/check-doc-sync.ts",
    "doctor": "bun scripts/doctor.ts",
    "doctor:full": "bun scripts/doctor.ts --full",
    "layers:graph": "bun scripts/layers-graph.ts",
    "layers:summary": "bun scripts/layers-graph.ts --summary",
    "scaffold:middleware": "bun scripts/scaffold-middleware.ts",
    "check:test-utils-migration": "bun scripts/check-test-utils-migration.ts",
    "generate:layer-docs": "bun scripts/generate-layer-docs.ts",
    "koi": "./packages/meta/cli/dist/bin.js",
    "changeset": "bunx changeset",
    "changeset:version": "bunx changeset version && bun install",
    "changeset:publish": "bunx changeset publish",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@changesets/cli": "^2.29.4",
    "@types/bun": "1.3.9",
    "@vercel/sandbox": "1.7.1",
    "e2b": "2.12.1",
    "lefthook": "2.1.1",
    "tsup": "^8.5.1",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "esbuild"
  ]
}
