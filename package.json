{
  "name": "koi-monorepo",
  "description": "Koi monorepo: self-extending agent engine with layered architecture, middleware, and governance",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "workspaces": [
    "packages/*/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:layers": "bun scripts/check-layers.ts",
    "check:descriptions": "bun scripts/check-descriptions.ts",
    "check:doc-sync": "bun scripts/check-doc-sync.ts",
    "doctor": "bun scripts/doctor.ts",
    "doctor:full": "bun scripts/doctor.ts --full",
    "layers:graph": "bun scripts/layers-graph.ts",
    "layers:summary": "bun scripts/layers-graph.ts --summary",
    "check:doc-gate": "bun scripts/check-doc-gate.ts",
    "check:test-integrity": "bun scripts/check-test-integrity.ts",
    "check:complexity": "bun scripts/check-complexity.ts",
    "generate:layer-docs": "bun scripts/generate-layer-docs.ts",
    "check:orphans": "bun scripts/check-orphans.ts",
    "check:golden-queries": "bun scripts/check-golden-queries.ts",
    "check:unused": "bunx knip",
    "check:duplicates": "bunx jscpd .",
    "changeset": "bunx changeset",
    "changeset:version": "bunx changeset version && bun install",
    "changeset:publish": "bunx changeset publish",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "1.3.11",
    "jscpd": "^4.0.8",
    "knip": "^6.2.0",
    "lefthook": "2.1.4",
    "tsup": "^8.5.1",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "trustedDependencies": [
    "esbuild"
  ]
}
