{
  "name": "koi",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "workspaces": [
    "packages/*/*",
    "apps/*",
    "tests/e2e",
    "recipes/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:layers": "bun scripts/check-layers.ts",
    "check:doc-sync": "bun scripts/check-doc-sync.ts",
    "generate:layer-docs": "bun scripts/generate-layer-docs.ts",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/bun": "1.3.9",
    "@vercel/sandbox": "1.7.1",
    "e2b": "2.12.1",
    "lefthook": "2.1.1",
    "tsup": "^8.5.1",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "esbuild"
  ]
}
