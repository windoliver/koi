{
  "$schema": "https://koi.dev/schemas/settings-v1.json",

  "permissions": {
    "defaultMode": "ask",
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git commit*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(sudo *)"
    ]
  },

  "env": {
    "KOI_LOG_LEVEL": "info"
  },

  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "./.koi/hooks/pre-tool.sh",
        "timeoutMs": 5000
      }
    ]
  },

  "theme": "dark"
}
