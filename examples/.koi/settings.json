{
  "$schema": "https://koi.dev/schemas/settings-v1.json",

  "permissions": {
    "defaultMode": "default",
    "allow": [
      "fs_read(*)",
      "Glob(*)",
      "Bash(git log*)",
      "Bash(git diff*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git commit*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(sudo *)",
      "web_fetch(*)"
    ]
  }
}
