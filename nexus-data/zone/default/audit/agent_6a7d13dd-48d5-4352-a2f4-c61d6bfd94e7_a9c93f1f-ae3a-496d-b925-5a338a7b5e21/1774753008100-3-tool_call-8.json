          "input": { "celsius": 37 },
          "expectedOutput": { "celsius": 37, "fahrenheit": 98.6 }
        },
        {
          "name": "Below zero",
          "input": { "celsius": -40 },
          "expectedOutput": { "celsius": -40, "fahrenheit": -40 }
