        },
        "required": ["celsius", "fahrenheit"]
      },
      "implementation": "\n({ celsius }) => {\n  const fahrenheit = (celsius * 9 / 5) + 32;\n  return { celsius, fahrenheit };\n}\n",
      "testCases": [
