      "name": "celsius_to_f",
      "description": "Converts a temperature value from Celsius to Fahrenheit using the standard formula: F = (C × 9/5) + 32",
      "inputSchema": {
        "type": "object",
        "properties": {
          "celsius": { "type": "number", "description": "Temperature in Celsius to convert" }
        },
        "required": ["celsius"]
