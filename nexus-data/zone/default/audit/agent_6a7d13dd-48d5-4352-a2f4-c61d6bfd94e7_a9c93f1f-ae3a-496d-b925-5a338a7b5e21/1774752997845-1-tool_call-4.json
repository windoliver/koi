        "required": ["celsius", "fahrenheit"]
      },
      "implementation": "\nexport default function celsius_to_f({ celsius }: { celsius: number }): { celsius: number; fahrenheit: number } {\n  const fahrenheit = (celsius * 9 / 5) + 32;\n  return { celsius, fahrenheit };\n}\n",
      "testCases": [
        {
          "name": "Freezing point",
          "input": { "celsius": 0 },
          "expectedOutput": { "celsius": 0, "fahrenheit": 32 }
        },
        {
          "name": "Boiling point",
          "input": { "celsius": 100 },
          "expectedOutput": { "celsius": 100, "fahrenheit": 212 }
        },
        {
          "name": "Body temperature",
          "input": { "celsius": 37 },
          "expectedOutput": { "celsius": 37, "fahrenheit": 98.6 }
        },
        {
          "name": "Below zero",
          "input": { "celsius": -40 },
          "expectedOutput": { "celsius": -40, "fahrenheit": -40 }
        }
      ],
