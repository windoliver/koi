  },
  "devDependencies": {
    "@koi/engine": "workspace:*",
    "@koi/engine-loop": "workspace:*",
    "@koi/engine-pi": "workspace:*",
    "@koi/model-router": "workspace:*",
    "@koi/test-utils": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test"
