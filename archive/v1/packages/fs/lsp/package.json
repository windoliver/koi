{
  "name": "@koi/lsp",
  "description": "Bridge any LSP server (TypeScript, Python, Go, Rust, etc.) into Koi's ECS tool system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test",
    "test:api": "bun test src/__tests__/api-surface.test.ts"
  },
  "dependencies": {
    "@koi/core": "workspace:*",
    "@koi/errors": "workspace:*",
    "@koi/validation": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@koi/engine": "workspace:*",
    "@koi/engine-pi": "workspace:*"
  }
}
