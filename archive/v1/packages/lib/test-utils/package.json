{
  "name": "@koi/test-utils",
  "description": "Provide mock agents, contract test suites, and spy utilities for testing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@koi/core": "workspace:*",
    "@koi/gateway-types": "workspace:*",
    "@koi/test-utils-mocks": "workspace:*",
    "@koi/test-utils-store-contracts": "workspace:*",
    "@koi/test-utils-contracts": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:api": "bun test src/__tests__/api-surface.test.ts",
    "lint": "biome check ."
  }
}
