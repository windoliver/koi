{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.ts", "tsconfig.json", "../../tsconfig.base.json"],
      "outputs": ["coverage/**"]
    },
    "test:api": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.ts", "dist/**/*.d.ts"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check:layers": {
      "inputs": ["packages/*/*/package.json", "packages/*/*/src/**/*.ts", "scripts/layers.ts"],
      "outputs": [],
      "cache": true
    }
  }
}
